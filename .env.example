# =============================================================================
#  apex-agents-bench .env  ---  copy to .env and fill in the keys you actually
#  use. Never commit .env. The .gitignore at repo root enforces this.
# =============================================================================

# --- Generation (test-model providers) --------------------------------------
# Set the key(s) for whichever provider(s) host the model(s) you want to test.
# You only need keys for providers you actually use.

# OpenAI -- required for gpt-5.5-* agent profiles AND for the judge (gpt-5.5).
# IMPORTANT: no leading/trailing whitespace around the `=`. python-dotenv
# will include any spaces in the value, which silently invalidates the key.
OPENAI_API_KEY=sk-...

# xAI -- required for grok-4.3-* agent profiles.
XAI_API_KEY=xai-...

# Anthropic direct API -- NOT used by this project. Claude profiles run via
# AWS Bedrock and are deferred until the same Bedrock plumbing lands in
# apex-bench. Leave commented out unless you explicitly add a Claude profile.
# ANTHROPIC_API_KEY=sk-ant-...

# Google -- NOT used. The project judge is gpt-5.5, not Gemini. The vendored
# Archipelago example defaults to gemini/gemini-2.5-flash; we override.
# GOOGLE_API_KEY=...

# --- AWS Bedrock (for claude-* profiles, currently deferred) ----------------
# Mirror of apex-bench. Not needed if you only run gpt-5.5-* or grok-4.3-*.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# --- HuggingFace (dataset fetch) --------------------------------------------
# REQUIRED. The mercor/apex-agents dataset is gated; HF login is required to
# accept the eval-only terms before the first download. After you accept the
# terms, paste the read-scoped token here.
HF_TOKEN=hf_...

# --- Document extraction (optional) -----------------------------------------
# Reducto is used by the vendor's grading runner to extract visual artifacts
# from PDFs / spreadsheets / slides / docs into images for the judge LLM to
# read. Grading works WITHOUT this key but loses visual context for any task
# where the agent produced a chart-heavy artifact. Most agent tasks (~88%)
# produce text answers and do not need it.
# REDUCTO_API_KEY=...
