# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
build/
dist/
pip-wheel-metadata/

# --- Virtualenvs ------------------------------------------------------------
.venv/
venv/
env/
ENV/

# --- Secrets ----------------------------------------------------------------
.env
.env.*
!.env.example

# --- Data, runs, caches -----------------------------------------------------
# Per-run small audit artifacts (results.csv, per-task trajectory.json,
# grades.json, configs) ARE tracked so collaborators can audit the run
# without re-executing it. Large per-task binaries (final_snapshot zips
# and the unpacked populate_world/ subdir) are excluded because they run
# ~750 MB per task.
data/
catalog/
results/
runs/**/final_snapshot.tar.gz
runs/**/final_snapshot.zip
runs/**/populate_world/
*.csv
!tests/**/*.csv
!docs/**/*.csv
!runs/**/*.csv

# --- Editor / OS ------------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# --- Jupyter ----------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_meta

# --- Vendored harness's own ephemera ----------------------------------------
# We vendor source, not artifacts.
vendor/archipelago/.venv/
vendor/archipelago/**/.venv/
vendor/archipelago/**/__pycache__/
vendor/archipelago/**/*.egg-info/
vendor/archipelago/**/build/
vendor/archipelago/**/dist/
vendor/archipelago/**/uv.lock
vendor/archipelago/**/.env
vendor/archipelago/**/output/
.antigravitycli
