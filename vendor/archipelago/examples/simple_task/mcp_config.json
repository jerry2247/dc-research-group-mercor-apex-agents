{
  "mcpServers": {
    "filesystem_server": {
      "transport": "stdio",
      "command": "uv",
      "args": [
        "run",
        "python",
        "main.py"
      ],
      "cwd": "/app/mcp_servers/filesystem/mcp_servers/filesystem_server",
      "env": {
        "APP_FS_ROOT": "/filesystem",
        "SERVER_NAME": "filesystem_server",
        "MCP_TRANSPORT": "stdio"
      }
    }
  }
}
